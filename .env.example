# ─── Copy this to .env for local development ─────────────────────
# Never commit .env to GitHub

NODE_ENV=development
PORT=3000

# JWT secret – use any long random string locally
JWT_SECRET=change-this-to-a-long-random-string

# ── FTP: office server ────────────────────────────────────────────
FTP_HOST=ftp.sdpipk.org
FTP_PORT=21
FTP_USER=dfltphase2@dfltphase2.sdpipk.org
FTP_PASS=your_ftp_password_here
FTP_REMOTE_DIR=/bisp_dashboard/

# ── SurveyCTO media proxy ─────────────────────────────────────────
# (these are also in confidentials/config.json when running locally)
SURVEYCTO_USER=dflt2_audio_reviewers@sdpi.org
SURVEYCTO_PASS=your_surveycto_password_here
